{
  "xsappname": "deep-approuter-app",
  "tenant-mode": "dedicated",
  
  "oauth2-configuration": {
      "redirect-uris": [
        "https://*.cfapps.us10-001.hana.ondemand.com/**"
      ]
    },

  "scopes": [
    {
      "name": "$XSAPPNAME.Adopter",
      "description": "Adopter role - can view animals and submit adoption applications"
    },
    {
      "name": "$XSAPPNAME.Admin",
      "description": "Admin role - full access to manage animals and applications"
    }
  ],
  "attributes": [],
  "role-templates": [
    {
      "name": "Adopter",
      "description": "Adopter - view animals, submit applications",
      "scope-references": [
        "$XSAPPNAME.Adopter"
      ],
      "attribute-references": []
    },
    {
      "name": "Admin",
      "description": "Admin - full access",
      "scope-references": [
        "$XSAPPNAME.Admin"
      ],
      "attribute-references": []
    }
  ],
  "role-collections": [
    {
      "name": "AnimalAdoption_Adopter",
      "description": "Adopter - can view and adopt animals",
      "role-template-references": [
        "$XSAPPNAME.Adopter"
      ]
    },
    {
      "name": "AnimalAdoption_Admin",
      "description": "Admin - full management access",
      "role-template-references": [
        "$XSAPPNAME.Admin"
      ]
    }
  ]
}